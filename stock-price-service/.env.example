# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@domain:port/database

# Earliest date to fetch when a ticker has no prior fetch history (optional, default: 2020-01-01)
DEFAULT_START_DATE=2020-01-01

AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
SQS_NEW_SYMBOL_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/stock-price-new-symbol-queue
